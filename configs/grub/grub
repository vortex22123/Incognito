# Incognito OS - GRUB Default Configuration
# /etc/default/grub

GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_DISTRIBUTOR="Incognito OS"
GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"
GRUB_CMDLINE_LINUX=""

# Uncomment to enable GRUB theme
GRUB_THEME="/boot/grub/themes/incognito/theme.txt"

# Resolution
GRUB_GFXMODE=1024x768
GRUB_GFXPAYLOAD_LINUX=keep

# Disable submenu
GRUB_DISABLE_SUBMENU=false

# Enable OS prober
GRUB_DISABLE_OS_PROBER=false
