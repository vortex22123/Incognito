# Incognito OS - default Tor config
# Dicopy ke /etc/tor/torrc oleh scripts/build/phase2-blfs-networking.sh

SocksPort 9050
ControlPort 9051
CookieAuthentication 1

# Transparent proxy support (dipakai oleh tor-toggle.sh untuk redirect iptables)
TransPort 9040
DNSPort 5353
AutomapHostsOnResolve 1

# Logging minimal, ke journal bukan file (biar hemat disk)
Log notice syslog

# Nonaktifkan jadi relay/exit node - ini cuma buat client privacy
SocksPolicy accept 127.0.0.1
ExitPolicy reject *:*
