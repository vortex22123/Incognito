<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="Incognito">
    <item label="Terminal">
      <action name="Execute"><command>alacritty</command></action>
    </item>
    <item label="File Manager">
      <action name="Execute"><command>pcmanfm</command></action>
    </item>
    <item label="Web Browser">
      <action name="Execute"><command>firefox</command></action>
    </item>
    <item label="Chromium">
      <action name="Execute"><command>chromium</command></action>
    </item>
    <separator/>
    <item label="Security Tools">
      <action name="Execute"><command>security-tools</command></action>
    </item>
    <item label="Tor Toggle">
      <action name="Execute"><command>toggle-tor</command></action>
    </item>
    <separator/>
    <item label="System Monitor">
      <action name="Execute"><command>htop</command></action>
    </item>
    <item label="Network Scan">
      <action name="Execute"><command>alacritty -e nmap -sn 192.168.1.0/24</command></action>
    </item>
    <item label="Text Editor">
      <action name="Execute"><command>alacritty -e nano</command></action>
    </item>
    <separator/>
    <item label="Lock Screen">
      <action name="Execute"><command>betterlockscreen -l dim</command></action>
    </item>
    <item label="Logout">
      <action name="Execute"><command>openbox --exit</command></action>
    </item>
    <item label="Shutdown">
      <action name="Execute"><command>systemctl poweroff</command></action>
    </item>
    <item label="Reboot">
      <action name="Execute"><command>systemctl reboot</command></action>
    </item>
    <separator/>
    <menu id="system-menu" label="System">
      <item label="Settings">
        <action name="Execute"><command>alacritty -e nmtui</command></action>
      </item>
      <item label="Update System">
        <action name="Execute"><command>alacritty -e bash -c 'apt update && apt upgrade -y'</command></action>
      </item>
      <item label="Clean System">
        <action name="Execute"><command>alacritty -e bash -c 'apt clean && apt autoclean'</command></action>
      </item>
      <item label="System Hardening">
        <action name="Execute"><command>alacritty -e system-hardening</command></action>
      </item>
    </menu>
    <menu id="accessories-menu" label="Accessories">
      <item label="Calculator">
        <action name="Execute"><command>alacritty -e bc -l</command></action>
      </item>
      <item label="Screenshot">
        <action name="Execute"><command>scrot /tmp/screenshot-%Y%m%d-%H%M%S.png</command></action>
      </item>
      <item label="Image Viewer">
        <action name="Execute"><command>feh</command></action>
      </item>
      <item label="Video Player">
        <action name="Execute"><command>mpv</command></action>
      </item>
    </menu>
    <menu id="network-menu" label="Network">
      <item label="Wireshark">
        <action name="Execute"><command>wireshark</command></action>
      </item>
      <item label="Tcpdump">
        <action name="Execute"><command>alacritty -e tcpdump</command></action>
      </item>
      <item label="Nmap">
        <action name="Execute"><command>alacritty -e nmap</command></action>
      </item>
      <item label="Netcat">
        <action name="Execute"><command>alacritty -e nc</command></action>
      </item>
    </menu>
  </menu>
  <menu id="client-menu" label="Window">
    <item label="Minimize"><action name="Iconify"/></item>
    <item label="Maximize"><action name="Maximize"/></item>
    <item label="Fullscreen"><action name="Fullscreen"/></action>
    <item label="Roll Up"><action name="RollUp"/></item>
    <item label="Roll Down"><action name="Unroll"/></item>
    <separator/>
    <item label="Move"><action name="Move"/></item>
    <item label="Resize"><action name="Resize"/></action>
    <separator/>
    <item label="Lower"><action name="Lower"/></item>
    <item label="Raise"><action name="Raise"/></item>
    <separator/>
    <item label="Close"><action name="Close"/></item>
    <item label="Kill"><action name="Kill"/></item>
  </menu>
</openbox_menu>
