<?xml version="1.0" encoding="utf-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">

  <menu id="root-menu" label="Incognito OS">
    <item label="Terminal">
      <action name="Execute"><command>x-terminal-emulator</command></action>
    </item>
    <item label="File Manager">
      <action name="Execute"><command>pcmanfm</command></action>
    </item>
    <separator/>
    <item label="Security Tools">
      <action name="Execute"><command>rofi -show drun -drun-categories Security</command></action>
    </item>
    <item label="Toggle Tor">
      <action name="Execute"><command>/usr/local/bin/tor-toggle toggle</command></action>
    </item>
    <separator/>
    <item label="Lock Screen">
      <action name="Execute"><command>i3lock -c 000000</command></action>
    </item>
    <item label="Reconfigure Openbox">
      <action name="Reconfigure"/>
    </item>
    <item label="Log Out">
      <action name="Exit"/>
    </item>
  </menu>

</openbox_menu>
