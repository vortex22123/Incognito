#!/bin/bash
# ~/.config/openbox/autostart - dijalankan otomatis saat Openbox session mulai
# (Catatan: picom & polybar sebenarnya sudah dipanggil dari .xinitrc juga;
#  ini fallback kalau desktop di-restart via Reconfigure tanpa restart X)

nitrogen --restore &
nm-applet &

# Set wallpaper default kalau belum ada state tersimpan nitrogen
if [ ! -f "$HOME/.config/nitrogen/bg-saved.cfg" ]; then
    feh --bg-scale /usr/share/backgrounds/incognito/default.png 2>/dev/null || true
fi
